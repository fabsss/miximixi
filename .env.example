# ==============================================
# Miximixi – Environment Variables
# Kopiere diese Datei zu .env und fülle die Werte aus
# WICHTIG: .env niemals in Git committen!
# ==============================================

# --- LLM Provider ---
# Optionen: ollama | gemini | claude | openai | openai_compat | gemma3n
# Empfehlung: gemini  (Cloud, native Video-Analyse, kein GPU nötig)
#             gemma3n (lokal via Ollama, 8-12GB VRAM, Frame-basiert)
#             ollama  (lokal, CPU-only, langsam aber kostenlos)
LLM_PROVIDER=ollama

# Google Gemini (bevorzugter Cloud-Provider)
# → Verarbeitet Instagram-Videos NATIV (kein ffmpeg Frame-Splitting)
# → API Key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Ollama (lokal, CPU-only)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2-vision:11b

# Claude API
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# OpenAI-kompatibler Endpoint (Groq, Together, etc.)
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=

# Gemma 3n (lokal via Ollama, Frame-basiert)
# → Benötigt Ollama mit gemma3n:e4b Model
# → RAM: 8-12GB VRAM mit bf16 Quantization
# → Ähnliche Qualität wie Gemini 2.5 Flash (lokal, kostenlos)
GEMMA3N_BASE_URL=http://ollama:11434
GEMMA3N_MODEL=gemma3n:e4b

# --- PostgreSQL Database ---
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=miximixi
DB_HOST=localhost
DB_PORT=5432

# --- Frontend & API URLs ---
# Frontend domain (used by Telegram bot for deep links)
# Also used by reverse proxy to serve the React app
# Format: https://your-domain.com (no trailing slash)
FRONTEND_DOMAIN=https://miximixi.example.com

# API endpoint (used by frontend JavaScript to call the backend)
# Usually same domain as FRONTEND_DOMAIN, but routed to backend API via reverse proxy
VITE_API_BASE_URL=https://miximixi-api.example.com

# --- Telegram ---
# WICHTIG für lokale Entwicklung:
# Wenn du das Backend lokal via `poetry run uvicorn` (oder start-backend-dev.cmd) startest,
# MUSS TELEGRAM_BOT_TOKEN hier LEER bleiben! Sonst laufen zwei Bot-Instanzen gleichzeitig
# (dev-machine + Proxmox-Server) und kämpfen um denselben Polling-Slot → 409 Conflict.
# Der Prod-Server auf Proxmox hat seinen eigenen .env mit dem echten Token.
# → Auf der Dev-Maschine: TELEGRAM_BOT_TOKEN= (leer lassen)
# → Auf dem Proxmox-Server: TELEGRAM_BOT_TOKEN=<echter-token>
TELEGRAM_BOT_TOKEN=
# Chat-ID für Fehler-Benachrichtigungen (needs_review-Jobs).
# Ermitteln: Nachricht an den Bot schicken, dann aufrufen:
# https://api.telegram.org/bot<TOKEN>/getUpdates → "chat": {"id": ...}
TELEGRAM_NOTIFY_CHAT_ID=
# Admin-IDs für /sync_* Befehle (komma-getrennt)
# Ermitteln: /start-Nachricht an den Bot schicken, in Backend-Logs nachschauen
TELEGRAM_ADMIN_IDS=123456789,987654321

# --- Instagram ---
# WICHTIG: Zweit-Account verwenden, nicht den Haupt-Account!
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=
INSTAGRAM_COLLECTION_ID=
# Cookies für yt-dlp (auf externem Volume)
INSTAGRAM_COOKIES_FILE=/mnt/data/miximixi/instagram_cookies.txt

# Playwright Browser-State (persistenter Login-Context, auf externem Volume)
INSTAGRAM_BROWSER_STATE_DIR=/mnt/data/miximixi/instagram_browser_state

# Cookie-Refresh-Einstellungen
INSTAGRAM_COOKIE_REFRESH_THRESHOLD_DAYS=7
INSTAGRAM_COOKIE_MAX_REFRESH_RETRIES=2
INSTAGRAM_COOKIE_RETRY_INTERVAL=1800

# --- Instagram Sync Worker ---
# Enable/disable automatic Instagram collection syncing
INSTAGRAM_SYNC_ENABLED=true
# Interval in seconds (15 min)
INSTAGRAM_SYNC_INTERVAL=900

# --- Frontend (Vite build args) ---
# These are baked into the JS bundle at build time (not runtime env vars).
# Dev: used by `npm run dev` / `vite` directly
# Production (docker-compose.yml): passed as Docker build ARGs to the frontend image
VITE_API_BASE_URL=https://miximixi-api.sektbirne.fun
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
