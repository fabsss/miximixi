# ==============================================
# Miximixi – Environment Variables
# Kopiere diese Datei zu .env und fülle die Werte aus
# WICHTIG: .env niemals in Git committen!
# ==============================================

# --- LLM Provider ---
# Optionen: ollama | gemini | claude | openai | openai_compat
# Empfehlung: gemini (Cloud, native Video-Analyse, kein GPU nötig)
#             ollama  (lokal, CPU-only, langsam aber kostenlos)
LLM_PROVIDER=ollama

# Google Gemini (bevorzugter Cloud-Provider)
# → Verarbeitet Instagram-Videos NATIV (kein ffmpeg Frame-Splitting)
# → API Key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Ollama (lokal, CPU-only)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2-vision:11b

# Claude API
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# OpenAI-kompatibler Endpoint (Groq, Together, etc.)
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=

# --- Supabase ---
SUPABASE_URL=http://supabase-api:8000
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Supabase interne Konfiguration (für docker-compose.yml)
POSTGRES_PASSWORD=your-super-secret-postgres-password
JWT_SECRET=your-super-secret-jwt-secret-min-32-chars
ANON_KEY=
SERVICE_ROLE_KEY=
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
# Chat-ID für Fehler-Benachrichtigungen (needs_review-Jobs).
# Ermitteln: Nachricht an den Bot schicken, dann aufrufen:
# https://api.telegram.org/bot<TOKEN>/getUpdates → "chat": {"id": ...}
TELEGRAM_NOTIFY_CHAT_ID=

# --- Instagram ---
# WICHTIG: Zweit-Account verwenden, nicht den Haupt-Account!
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=
INSTAGRAM_COLLECTION_ID=

# --- n8n ---
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=
N8N_ENCRYPTION_KEY=

# --- Frontend (Vite) ---
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=
VITE_API_BASE_URL=http://localhost:8000
