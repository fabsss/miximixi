# ==============================================
# Vaultwarden Stack Environment Variables
# Kopiere diese Datei zu .env (im gleichen Verzeichnis wie docker-compose.vaultwarden.yml)
# ==============================================

# --- Vaultwarden Admin ---
# Admin token für /admin Zugriff (in vaultwarden-admin service)
ADMIN_TOKEN=<change-me-to-secure-token>

# --- Vaultwarden API Server ---
# Credentials für die Vaultwarden-API Server (miximixi Backend Zugriff)
VAULTWARDEN_URL=http://vaultwarden:80
VAULTWARDEN_EMAIL=miximixi@marty-docker
VAULTWARDEN_PASSWORD=<your-master-password>
VAULTWARDEN_API_KEY=<generate-32-char-api-key>
