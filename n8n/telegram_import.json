{
  "name": "Miximixi – Telegram Import",
  "nodes": [
    {
      "parameters": {
        "updates": ["message"],
        "additionalFields": {}
      },
      "id": "telegram-trigger",
      "name": "Telegram Trigger",
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1,
      "position": [240, 300],
      "credentials": {
        "telegramApi": {
          "id": "telegram-bot",
          "name": "Miximixi Telegram Bot"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// URL aus Telegram-Nachricht extrahieren\nconst message = $input.first().json.message;\nconst text = message?.text || '';\nconst chatId = message?.chat?.id;\nconst messageId = message?.message_id;\n\n// Beliebige URL erkennen (Instagram, YouTube, Website, etc.)\nconst urlPattern = /https?:\\/\\/[^\\s]+/gi;\nconst matches = text.match(urlPattern);\n\nif (!matches || matches.length === 0) {\n  return [{\n    json: {\n      valid: false,\n      chat_id: chatId,\n      message_id: messageId,\n      error: 'Kein Link gefunden. Schick mir einen Link wie https://www.instagram.com/p/... oder https://www.rezept.de/...'\n    }\n  }];\n}\n\nconst url = matches[0].split('?')[0]; // Query-Parameter entfernen\n\n// Source-Type erkennen\nfunction detectSourceType(url) {\n  if (/instagram\\.com/i.test(url)) return 'instagram';\n  if (/(youtube\\.com|youtu\\.be)/i.test(url)) return 'youtube';\n  return 'web';\n}\n\nreturn [{\n  json: {\n    valid: true,\n    url: url,\n    source_type: detectSourceType(url),\n    chat_id: chatId,\n    message_id: messageId\n  }\n}];"
      },
      "id": "extract-url",
      "name": "URL extrahieren",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "leftValue": "={{ $json.valid }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "check-valid",
      "name": "URL gültig?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [680, 300]
    },
    {
      "parameters": {
        "chatId": "={{ $json.chat_id }}",
        "text": "={{ $json.error }}",
        "additionalFields": {
          "reply_to_message_id": "={{ $json.message_id }}"
        }
      },
      "id": "send-error",
      "name": "Fehler senden",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [900, 460],
      "credentials": {
        "telegramApi": {
          "id": "telegram-bot",
          "name": "Miximixi Telegram Bot"
        }
      }
    },
    {
      "parameters": {
        "chatId": "={{ $json.chat_id }}",
        "text": "⏳ Link erkannt! Rezept wird importiert…",
        "additionalFields": {
          "reply_to_message_id": "={{ $json.message_id }}"
        }
      },
      "id": "send-ack",
      "name": "Bestätigung senden",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [900, 160],
      "credentials": {
        "telegramApi": {
          "id": "telegram-bot",
          "name": "Miximixi Telegram Bot"
        }
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.BACKEND_URL }}/import",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"url\": \"{{ $('URL extrahieren').item.json.url }}\",\n  \"source_type\": \"{{ $('URL extrahieren').item.json.source_type }}\"\n}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "call-backend",
      "name": "Backend /import aufrufen",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1120, 160]
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst chatId = $('Bestätigung senden').item.json.chat_id;"\n\nlet messageText = '';\n\nif (response.message && response.message.includes('existiert bereits')) {\n  messageText = `⚠️ ${response.message}\\n\\nDieses Rezept ist schon in deiner Sammlung!`;\n} else if (response.status === 'needs_review') {\n  let errorDetails = '';\n  if (response.error_msg) {\n    const err = response.error_msg.toLowerCase();\n    if (err.includes('download') || err.includes('404') || err.includes('connection')) {\n      errorDetails = '\\n\\n❌ Video/Seite konnte nicht heruntergeladen werden.\\n\\nÜberprüfe die URL oder versuche es später erneut.';\n    } else if (err.includes('cookie') || err.includes('instagram') || err.includes('unauthorized')) {\n      errorDetails = '\\n\\n❌ Zugriff auf Instagram oder andere Seite fehlgeschlagen.\\n\\nDies kann ein Cookie-Fehler sein. Versuche es später erneut.';\n    } else if (err.includes('recipe') || err.includes('extract') || err.includes('parsing')) {\n      errorDetails = '\\n\\n❌ Kein Rezept im Video oder auf der Seite gefunden.\\n\\nVielleicht ist das Video kein Rezept oder die Seite enthält keine Rezeptinformationen.';\n    } else if (err.includes('timeout')) {\n      errorDetails = '\\n\\n❌ Verarbeitung hat zu lange gedauert.\\n\\nVersuche es später erneut.';\n    } else {\n      errorDetails = `\\n\\n❌ Fehler beim Import: ${response.error_msg.substring(0, 100)}`;\n    }\n  } else {\n    errorDetails = '\\n\\n❌ Import fehlgeschlagen.\\n\\nVersuche es später erneut.';\n  }\n  messageText = `⚠️ Rezept konnte nicht verarbeitet werden.${errorDetails}`;\n} else if (response.queue_id && (response.status === 'pending' || response.status === 'processing')) {\n  messageText = `⏳ ${response.message || 'Rezept wird gerade verarbeitet…'}\\n\\nEs erscheint gleich in der App.`;\n} else if (response.status === 'done' && response.queue_id) {\n  messageText = `✅ Rezept erfolgreich importiert!\\n\\nEs ist jetzt in deiner App verfügbar. 🎉`;\n} else {\n  messageText = `ℹ️ Import-Status: ${response.status}\\n\\n${response.message || 'Bitte versuche es später erneut.'}`;\n}\n\nreturn [{ json: { chat_id: chatId, message: messageText } }];"
      },
      "id": "process-response",
      "name": "Backend-Response verarbeiten",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1340, 160]
    },
    {
      "parameters": {
        "chatId": "={{ $json.chat_id }}",
        "text": "={{ $json.message }}",
        "additionalFields": {}
      },
      "id": "send-status",
      "name": "Status-Nachricht senden",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [1540, 160],
      "credentials": {
        "telegramApi": {
          "id": "telegram-bot",
          "name": "Miximixi Telegram Bot"
        }
      }
    }
  ],
  "connections": {
    "Telegram Trigger": {
      "main": [
        [{"node": "URL extrahieren", "type": "main", "index": 0}]
      ]
    },
    "URL extrahieren": {
