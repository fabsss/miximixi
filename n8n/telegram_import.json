      ]
    },
    "Bestätigung senden": {
      "main": [
        [{"node": "Backend /import aufrufen", "type": "main", "index": 0}]
      ]
    },
    "Backend /import aufrufen": {
      "main": [
        [{"node": "Backend-Response verarbeiten", "type": "main", "index": 0}]
      ]
    },
    "Backend-Response verarbeiten": {
      "main": [
        [{"node": "Status-Nachricht senden", "type": "main", "index": 0}]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  },
  "meta": {
