{
  "expo": {
    "name": "Miximixi",
    "slug": "miximixi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "miximixi",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#fff8f4"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "fun.sektbirne.miximixi"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#fff8f4"
      },
      "package": "fun.sektbirne.miximixi"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app needs access to your photos to upload recipe images."
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./node_modules/@expo/vector-icons/build/vendor/react-native-vector-icons/Fonts/MaterialCommunityIcons.ttf",
            "./assets/fonts/NotoSerif_400Regular.ttf",
            "./assets/fonts/NotoSerif_700Bold.ttf",
            "./assets/fonts/PlusJakartaSans_400Regular.ttf",
            "./assets/fonts/PlusJakartaSans_500Medium.ttf",
            "./assets/fonts/PlusJakartaSans_600SemiBold.ttf",
            "./assets/fonts/PlusJakartaSans_700Bold.ttf"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiBaseUrl": "https://miximixi-api.sektbirne.fun"
    }
  }
}
