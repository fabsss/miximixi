    "clsx": "^2.1.1",
    "expo": "~52.0.46",
    "expo-av": "~15.0.2",
    "expo-blur": "~14.0.3",
    "expo-constants": "~17.0.8",
    "expo-font": "~13.0.4",
    "expo-image-picker": "~16.0.6",
    "expo-keep-awake": "~14.0.3",
    "expo-linking": "~7.0.5",
