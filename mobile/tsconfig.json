{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@miximixi/shared": ["../shared/src/index.ts"],
      "@miximixi/shared/*": ["../shared/src/*"],
      "@shared/*": ["../shared/src/*"],
      "@/*": ["src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.d.ts", "expo-env.d.ts"],
  "exclude": ["**/__tests__/**", "**/*.test.ts", "**/*.test.tsx", "node_modules"]
}
